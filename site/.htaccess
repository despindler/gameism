Options -Indexes

<FilesMatch "^\.env">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Deny from all
    </IfModule>
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteRule ^app(?:/|$) - [F,L]
    RewriteRule ^assets/ - [L]
    RewriteRule ^index\.php$ - [L]
    RewriteRule ^.*$ index.php [L]
</IfModule>
